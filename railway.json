{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "python quickstart/manage.py collectstatic --noinput"
  },
  "deploy": {
    "startCommand": "cd quickstart && gunicorn quickstart.wsgi:application --bind 0.0.0.0:$PORT",
    "healthcheckPath": "/api/docs/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
